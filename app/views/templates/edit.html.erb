<% content_for :hide_navbar, true %>

<style>
  /* ── Full-bleed, dark canvas ── */
  body { background: #F4EFE6 !important; }
  .max-w-6xl { max-width: none !important; padding: 0 !important; margin: 0 !important; }
  template-builder { display: block !important; background: #F4EFE6; min-height: 100vh; }

  /* ── Header bar ── */
  template-builder #title_container {
    background: rgba(244,239,230,0.97) !important;
    border-bottom: 1px solid #E0D7C7 !important;
    padding: 0 1.75rem !important;
    height: 56px !important;
    min-height: 56px !important;
  }
  template-builder .template-name {
    color: #1F1B14 !important;
    font-family: 'Space Grotesk', sans-serif !important;
    font-size: 1rem !important;
    font-weight: 500 !important;
    letter-spacing: -0.01em !important;
  }

  /* ── Submitter tabs (in header) ── */
  .bld-submitter-tabs { display: flex; gap: 0; }
  .bld-submitter-tab {
    font-family: 'Space Mono', monospace;
    font-size: 0.58rem; letter-spacing: 0.14em; text-transform: uppercase;
    color: rgba(31,27,20,0.4);
    padding: 0.45rem 1.1rem;
    border: 1px solid #E0D7C7; border-right: none;
    transition: color 0.15s, background 0.15s;
    cursor: pointer; background: transparent; white-space: nowrap;
  }
  .bld-submitter-tab:last-child { border-right: 1px solid #E0D7C7; }
  .bld-submitter-tab:hover { color: #1F1B14; background: rgba(31,27,20,0.04); }
  .bld-submitter-tab.bld-active { color: #FF6A3D; border-color: rgba(255,106,61,0.4); background: rgba(255,106,61,0.05); }

  /* ── Base / save / send buttons ── */
  template-builder .base-button {
    background: #E0D7C7 !important; color: rgba(31,27,20,0.65) !important;
    border: 1px solid #E0D7C7 !important; border-radius: 0 !important;
    font-family: 'Space Mono', monospace !important;
    font-size: 0.58rem !important; letter-spacing: 0.12em !important; text-transform: uppercase !important;
  }
  template-builder .base-button:hover { background: #E0D7C7 !important; color: #1F1B14 !important; }
  template-builder .white-button {
    background: #FF6A3D !important; color: #FFFFFF !important;
    border: none !important; border-radius: 0 !important;
    font-family: 'Space Mono', monospace !important;
    font-size: 0.58rem !important; letter-spacing: 0.12em !important; text-transform: uppercase !important;
  }
  template-builder .white-button:hover { background: #FF8060 !important; }
  template-builder .btn-primary.btn-ghost {
    color: rgba(31,27,20,0.5) !important;
    font-family: 'Space Mono', monospace !important;
    font-size: 0.58rem !important; letter-spacing: 0.12em !important;
  }

  /* ── Info bar ── */
  .bld-info-bar {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.55rem 1.75rem;
    background: #F4EFE6; border-bottom: 1px solid rgba(224,215,199,0.5);
    font-family: 'Space Mono', monospace; font-size: 0.5rem;
    letter-spacing: 0.14em; text-transform: uppercase; color: rgba(31,27,20,0.25);
  }

  /* ── Main canvas ── */
  template-builder #main_container { background: #F4EFE6 !important; }
  template-builder #pages_container { background: #F4EFE6 !important; }

  /* ── Right panel ── */
  template-builder #fields_list_container {
    background: #F4EFE6 !important;
    border-left: 1px solid rgba(224,215,199,0.5) !important;
    padding-right: 0 !important;
    padding-top: 0 !important;
  }

  /* ── Recipient header (right panel) ── */
  .bld-recipient-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.65rem 0.75rem;
    border-bottom: 1px solid rgba(224,215,199,0.5);
    margin-bottom: 0; flex-shrink: 0;
  }
  .bld-recipient-name {
    font-family: 'Space Mono', monospace; font-size: 0.55rem;
    letter-spacing: 0.14em; text-transform: uppercase; color: #FF6A3D;
    display: flex; align-items: center; gap: 0.35rem;
  }
  .bld-recipient-name::before {
    content: ''; display: inline-block;
    width: 7px; height: 7px; border-radius: 50%; background: #FF6A3D;
  }
  .bld-recipient-label {
    font-family: 'Space Mono', monospace; font-size: 0.5rem;
    letter-spacing: 0.12em; text-transform: uppercase; color: rgba(31,27,20,0.2);
  }

  /* ── Submitter/roles dropdown ── */
  template-builder .roles-dropdown {
    display: none !important;
  }

  /* ── Add signer "+" button ── */
  template-builder .add-signer-btn {
    flex-shrink: 0;
    width: 32px; height: 32px;
    border: 1px solid rgba(255,106,61,0.4) !important;
    border-radius: 0 !important;
    background: transparent !important;
    color: #FF6A3D !important;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s;
  }
  template-builder .add-signer-btn:hover {
    background: rgba(255,106,61,0.08) !important;
    border-color: #FF6A3D !important;
  }

  /* ── Field types list (replacing 3-col grid) ── */
  .bld-field-types-header {
    font-family: 'Space Mono', monospace; font-size: 0.5rem;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(31,27,20,0.22);
    padding: 0.55rem 0.75rem;
    border-bottom: 1px solid rgba(224,215,199,0.5);
  }
  template-builder #field-types-list {
    display: flex !important; flex-direction: column !important;
    gap: 0 !important; padding-bottom: 0 !important;
  }
  template-builder #field-types-list .field-type-button,
  template-builder #field-types-list .fields-grid-item {
    display: flex !important; flex-direction: row !important;
    align-items: center !important; gap: 0.7rem !important;
    padding: 0.6rem 0.75rem !important;
    border: none !important; border-bottom: 1px solid rgba(31,27,20,0.04) !important;
    border-radius: 0 !important; width: 100% !important; text-align: left !important;
    background: transparent !important; cursor: pointer !important;
    transition: background 0.15s !important;
  }
  template-builder #field-types-list .field-type-button:hover,
  template-builder #field-types-list .fields-grid-item:hover {
    background: rgba(31,27,20,0.025) !important;
  }
  template-builder #field-types-list .field-type-button .flex.items-console { display: none !important; }
  template-builder #field-types-list .field-type-button .flex.items-center.flex-col,
  template-builder #field-types-list .fields-grid-item .flex.items-center.flex-col {
    flex-direction: row !important; align-items: center !important;
    padding: 0 !important; gap: 0.7rem !important;
  }
  template-builder #field-types-list .bld-type-icon {
    width: 30px; height: 30px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    border: 1px solid rgba(31,27,20,0.1); color: rgba(31,27,20,0.4);
  }
  template-builder #field-types-list .field-type-button:hover .bld-type-icon { color: #FF6A3D !important; border-color: rgba(255,106,61,0.3) !important; }
  template-builder #field-types-list .bld-type-info { display: flex; flex-direction: column; }
  template-builder #field-types-list .bld-type-name {
    font-family: 'Space Mono', monospace; font-size: 0.52rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(31,27,20,0.7); line-height: 1.2;
  }
  template-builder #field-types-list .bld-type-desc {
    font-family: 'Space Grotesk', sans-serif; font-size: 0.68rem;
    color: rgba(31,27,20,0.25); line-height: 1.3; margin-top: 0.08rem;
  }
  template-builder #field-types-list .text-xs { display: none !important; }

  /* ── HOW TO USE section ── */
  .bld-howto { padding: 0.75rem; border-top: 1px solid rgba(224,215,199,0.5); }
  .bld-howto-header {
    font-family: 'Space Mono', monospace; font-size: 0.48rem;
    letter-spacing: 0.16em; text-transform: uppercase;
    color: rgba(31,27,20,0.15); margin-bottom: 0.6rem;
  }
  .bld-howto-item {
    font-family: 'Space Grotesk', sans-serif; font-size: 0.73rem;
    color: rgba(31,27,20,0.32); line-height: 1.5;
    padding: 0.15rem 0 0.15rem 1rem; position: relative;
  }
  .bld-howto-item::before { content: '—'; position: absolute; left: 0; color: rgba(255,106,61,0.5); }

  /* ── Autodetect button ── */
  template-builder .bld-autodetect-btn {
    background: transparent !important;
    border: 1px solid rgba(255,106,61,0.3) !important; color: #FF6A3D !important;
    border-radius: 0 !important;
    font-family: 'Space Mono', monospace !important; font-size: 0.52rem !important;
    letter-spacing: 0.12em !important; text-transform: uppercase !important;
    width: 100% !important; padding: 0.7rem !important; margin: 0.5rem 0 !important;
  }
  template-builder .bld-autodetect-btn:hover { background: rgba(255,106,61,0.04) !important; }

  /* ── Dropzone ── */
  template-builder .dropzone, template-builder [class*="dropzone"] {
    border-color: #E0D7C7 !important;
    background: rgba(31,27,20,0.02) !important; color: rgba(31,27,20,0.5) !important;
  }
  template-builder [class*="dropzone"] a { color: #FF6A3D !important; }
  template-builder [class*="dropzone"] span { color: rgba(31,27,20,0.15) !important; }

  /* ── Placed field list items (top-right panel boxes) ── */
  template-builder .fields-list-item {
    background: #FFFFFF !important;
    border: 1px solid #E0D7C7 !important;
    border-radius: 0 !important;
    color: #1F1B14 !important;
  }
  template-builder .fields-list-item * {
    color: #1F1B14 !important;
  }
  template-builder .fields-list-item input,
  template-builder .fields-list-item [contenteditable] {
    color: #1F1B14 !important;
  }
</style>

<% if current_user.created_at > 2.weeks.ago || params[:tour] == 'true' %>
  <% user_config = current_user.user_configs.find_or_initialize_by(key: UserConfig::SHOW_APP_TOUR) %>
  <% @show_tour_start_form = user_config.new_record? && !params.key?(:tour) %>
  <% if user_config.new_record? || user_config.value || params[:tour] == 'true' %>
    <app-tour data-show-tour="<%= params[:tour] == 'true' || user_config.value %>" data-type="builder" data-next-page-path="<%= template_path(@template, params.permit(:tour)) %>" data-i18n="<%= t('app_tour').to_json %>"></app-tour>
    <%= button_to nil, user_configs_path, method: :post, params: { user_config: { key: UserConfig::SHOW_APP_TOUR, value: true } }, class: 'hidden', id: 'start_tour_button' %>
  <% end %>
<% end %>
<template-builder
  class="grid"
  data-template="<%= @template_data %>"
  data-background-color="#F4EFE6"
  data-custom-fields="<%= (current_account.account_configs.find_or_initialize_by(key: AccountConfig::TEMPLATE_CUSTOM_FIELDS_KEY).value || []).to_json %>"
  data-with-sign-yourself-button="<%= !@template.archived_at? %>"
  data-with-fields-detection="true"
  data-with-send-button="<%= !@template.archived_at? && can?(:create, @template.submissions.new(account: current_account)) %>"
  data-locale="<%= I18n.locale %>"
  data-show-tour-start-form="<%= @show_tour_start_form %>"
></template-builder>
