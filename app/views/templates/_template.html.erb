<div class="relative group border border-base-300 rounded-lg p-4 hover:border-base-content/20 transition-colors" data-targets="dashboard-dropzone.templateCards">
  <div class="flex items-start justify-between gap-2">
    <a href="<%= template_path(template) %>" class="flex items-start gap-3 flex-1 min-w-0">
      <%= svg_icon('file_text', class: 'w-6 h-6 text-primary flex-shrink-0 mt-0.5') %>
      <div class="min-w-0">
        <div class="font-bold text-sm leading-tight truncate" data-targets="dashboard-dropzone.hiddenOnDrag">
          <% if template.template_accesses.present? %>
            <%= svg_icon('lock', class: 'w-4 h-4 inline -translate-y-[3px]') %>
          <% end %>
          <% template.name.split(/(_)/).each do |item| %><%= item %><wbr><% end %>
        </div>
        <div class="text-xs text-base-content/50 mt-0.5 truncate">
          <%= template.folder&.full_name.presence || TemplateFolder::DEFAULT_NAME %>
          <% if template.account_id != current_account.id %>
            <span class="badge badge-neutral badge-outline badge-sm text-[10px] uppercase ml-1"><%= t('shared') %></span>
          <% end %>
        </div>
      </div>
    </a>
    <div class="flex-shrink-0 flex flex-col gap-1" data-targets="dashboard-dropzone.hiddenOnDrag">
      <% if can?(:destroy, template) %>
        <%= button_to template_path(template), data: template.archived_at? ? { turbo_confirm: t('template_deletion_is_irreversible_and_will_permanently_remove_all_associated_signed_documents_with_it_are_you_sure_') } : {}, params: { permanently: template.archived_at? }.compact_blank, method: :delete, class: 'btn btn-ghost btn-circle btn-xs', aria_label: template.archived_at? ? t('delete') : t('archive') do %>
          <%= svg_icon(template.archived_at? ? 'trash' : 'archive', class: 'w-4 h-4 enabled text-base-content/40 hover:text-error') %>
          <%= svg_icon('loader', class: 'w-4 h-4 animate-spin disabled') %>
        <% end %>
      <% end %>
    </div>
  </div>
  <a href="<%= template_path(template) %>" class="mt-4 flex justify-between text-xs block" data-targets="dashboard-dropzone.hiddenOnDrag">
    <div>
      <div class="text-primary uppercase tracking-widest text-[10px] font-medium"><%= t('created') %></div>
      <div class="text-base-content/70 mt-0.5"><%= l(template.created_at.in_time_zone(current_account.timezone), format: :short, locale: current_account.locale) %></div>
    </div>
    <div class="text-right">
      <div class="text-primary uppercase tracking-widest text-[10px] font-medium"><%= t('modified') %></div>
      <div class="text-base-content/70 mt-0.5"><%= l(template.updated_at.in_time_zone(current_account.timezone), format: :short, locale: current_account.locale) %></div>
    </div>
  </a>
</div>
