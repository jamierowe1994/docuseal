<style>
  /* ── BSC PAGE BASE ── */
  .bsc {
    font-family: 'Space Grotesk', sans-serif;
    background: #141414;
    color: #fff;
    margin: -2rem calc(50% - 50vw) 0;
    padding: 0;
    min-height: 100vh;
  }
  .bsc ~ * { display: none !important; }
  .bsc *, .bsc *::before, .bsc *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .bsc a { text-decoration: none; }
  .bsc-g { color: #6bde2c; }
  .bsc-inner {
    padding: 5rem 5rem 6rem;
    max-width: 1600px;
    margin: 0 auto;
  }
  .bsc-seclbl {
    font-family: 'Space Mono', monospace; font-size: 0.85rem;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.3); margin-bottom: 1.5rem;
  }
  .bsc-sectitle {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 900;
    font-size: clamp(3rem, 5.5vw, 5.5rem); line-height: 0.92;
    text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 1.25rem;
  }
  .bsc-secsub {
    color: rgba(255,255,255,0.5); font-size: 1rem;
    line-height: 1.6; max-width: 36rem; margin-bottom: 3rem;
  }

  /* ── CARDS ── */
  .bsc-card {
    border: 1px solid rgba(255,255,255,0.1);
    background: #1a1a1a;
    padding: 2rem;
    margin-bottom: 2rem;
  }
  .bsc-card-title {
    font-family: 'Space Mono', monospace; font-size: 0.65rem;
    letter-spacing: 0.18em; text-transform: uppercase;
    color: rgba(255,255,255,0.35); margin-bottom: 1rem;
  }
  .bsc-card-heading {
    font-size: 1.1rem; font-weight: 600; color: #fff; margin-bottom: 1rem;
  }

  /* ── API TOKEN ROW ── */
  .bsc-token-row {
    display: flex; align-items: stretch; gap: 0.75rem; flex-wrap: wrap;
  }
  .bsc-token-input {
    flex: 1; min-width: 200px;
    background: #111; border: 1px solid rgba(255,255,255,0.18);
    color: #a3e85c; font-family: 'Space Mono', monospace; font-size: 0.8rem;
    padding: 0.7rem 1rem; outline: none;
  }
  .bsc-token-input:focus { border-color: rgba(107,222,44,0.45); }
  .bsc-token-btn {
    background: rgba(255,255,255,0.05); color: rgba(255,255,255,0.7);
    border: 1px solid rgba(255,255,255,0.18); font-family: 'Space Mono', monospace;
    font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 0.7rem 1.25rem; cursor: pointer; white-space: nowrap;
    transition: background 0.15s, color 0.15s;
  }
  .bsc-token-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }
  .bsc-token-btn-green {
    background: #6bde2c; color: #0a0a0a; font-family: 'Space Mono', monospace;
    font-size: 0.6rem; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 0.7rem 1.25rem; cursor: pointer; white-space: nowrap;
    border: none; transition: background 0.15s;
  }
  .bsc-token-btn-green:hover { background: #7fe83d; }

  /* ── CODE BLOCKS ── */
  .bsc-accordion {
    border: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 0.75rem;
    background: #1a1a1a;
  }
  .bsc-accordion-head {
    padding: 1.25rem 1.5rem; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    list-style: none;
    font-size: 0.95rem; font-weight: 500; color: rgba(255,255,255,0.85);
  }
  .bsc-accordion-head::-webkit-details-marker { display: none; }
  .bsc-accordion-meta {
    display: flex; gap: 0.5rem; align-items: center; margin-top: 0.35rem;
  }
  .bsc-badge-method {
    font-family: 'Space Mono', monospace; font-size: 0.5rem;
    letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.2rem 0.5rem; border: 1px solid;
  }
  .bsc-badge-post { color: #f5c842; border-color: rgba(245,200,66,0.4); background: rgba(245,200,66,0.06); }
  .bsc-badge-get  { color: #6bbfde; border-color: rgba(107,191,222,0.4); background: rgba(107,191,222,0.06); }
  .bsc-badge-endpoint {
    font-family: 'Space Mono', monospace; font-size: 0.55rem;
    color: rgba(255,255,255,0.4); letter-spacing: 0.04em;
  }
  .bsc-accordion-body {
    border-top: 1px solid rgba(255,255,255,0.08);
    padding: 0; overflow-x: auto; position: relative;
  }
  .bsc-accordion-body pre {
    background: #111; color: #c9d1d9; font-family: 'Space Mono', monospace;
    font-size: 0.72rem; line-height: 1.75; padding: 1.5rem; margin: 0;
    overflow-x: auto; white-space: pre-wrap; word-break: break-all;
  }
  .bsc-copy-btn {
    position: absolute; top: 0.75rem; right: 0.75rem;
    background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.18);
    color: rgba(255,255,255,0.5); font-family: 'Space Mono', monospace;
    font-size: 0.55rem; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.3rem 0.65rem; cursor: pointer; transition: background 0.15s;
  }
  .bsc-copy-btn:hover { background: rgba(255,255,255,0.1); color: #fff; }

  /* ── DOCS LINK ── */
  .bsc-docs-link {
    display: inline-block; margin-top: 2rem;
    background: #6bde2c; color: #0a0a0a; font-family: 'Space Mono', monospace;
    font-size: 0.7rem; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;
    padding: 0.85rem 2rem; transition: background 0.15s;
  }
  .bsc-docs-link:hover { background: #7fe83d; color: #0a0a0a; }

  /* ── RESPONSIVE ── */
  @media (max-width: 860px) {
    .bsc-inner { padding: 3rem 1.5rem 4rem; }
    .bsc-token-row { flex-direction: column; }
  }
</style>

<div class="bsc">
  <div class="bsc-inner">

    <%# ── HEADER ── %>
    <p class="bsc-seclbl"><span class="bsc-g">001</span> &mdash; INTEGRATIONS</p>
    <h1 class="bsc-sectitle">INTEGRATE.</h1>
    <p class="bsc-secsub">Connect Backed.sign to your existing workflow with our REST API. Automate document requests, manage templates, and track signatures programmatically.</p>

    <%# ── API TOKEN CARD ── %>
    <div class="bsc-card">
      <p class="bsc-card-title">API Authentication</p>
      <p class="bsc-card-heading">X-Auth-Token</p>
      <div class="bsc-token-row">
        <% token = current_user.access_token.token %>
        <% obscured_token = token.sub(token[5..], '*' * token[5..].size) %>
        <% if current_account.testing? %>
          <masked-input class="flex-1" data-token="<%= token %>">
            <input id="api_key" type="text" value="<%= obscured_token %>" class="bsc-token-input" autocomplete="off" readonly style="width:100%">
          </masked-input>
          <%= render 'shared/clipboard_copy', icon: 'copy', text: token, class: 'bsc-token-btn', icon_class: 'w-4 h-4', copy_title: t('copy'), copied_title: t('copied') %>
        <% else %>
          <a id="access_token_container" href="<%= settings_reveal_access_token_path %>" data-turbo-frame="modal" class="flex flex-1 gap-3">
            <input id="api_key" type="text" value="<%= obscured_token %>" class="bsc-token-input" autocomplete="off" readonly style="width:100%">
            <div class="bsc-token-btn">
              <%= svg_icon('copy', class: 'w-4 h-4') %>
              <span><%= t('copy') %></span>
            </div>
          </a>
        <% end %>
        <%= button_to button_title(title: t('rotate'), disabled_with: t('rotate'), icon: svg_icon('reload', class: 'w-4 h-4')), settings_api_index_path, class: 'bsc-token-btn', data: { turbo_confirm: t('remove_existing_api_token_and_generated_a_new_one_are_you_sure_') } %>
      </div>
    </div>

    <%# ── CODE EXAMPLES ── %>
    <p class="bsc-card-title" style="margin-bottom:1.25rem">Code Examples</p>

    <details class="bsc-accordion">
      <summary class="bsc-accordion-head">
        <span>
          <%= t('request_signature_multiple_submitters_with_default_values') %>
          <div class="bsc-accordion-meta">
            <span class="bsc-badge-method bsc-badge-post">POST</span>
            <span class="bsc-badge-endpoint"><%= api_submissions_path %></span>
          </div>
        </span>
      </summary>
      <div class="bsc-accordion-body">
        <% text = capture do %>curl --location '<%= api_submissions_url %>' \
     --header 'X-Auth-Token: API_TOKEN' \
     --data-raw '{
       "template_id": <%= current_account.templates.last&.id || 1 %>,
       "submitters": [
         {
           "name": "John Doe",
           "role": "<%= current_account.templates.last ? current_account.templates.last.submitters.first['name'] : 'First Party' %>",
           "email": "<%= current_user.email.sub('@', '+test@') %>",
           "values": { "Form Text Field Name": "Default Value" }
         },
         { "role": "Second Submitter", "email": "<%= current_user.email.sub('@', '+test2@') %>" }
       ]
     }'<% end.to_str %>
        <%= render 'shared/clipboard_copy', icon: 'copy', text:, class: 'bsc-copy-btn', icon_class: 'w-3 h-3', copy_title: t('copy'), copied_title: t('copied') %>
        <pre><%== HighlightCode.call(text, 'Shell', theme: 'base16.dark') %></pre>
      </div>
    </details>

    <details class="bsc-accordion">
      <summary class="bsc-accordion-head">
        <span>
          <%= t('request_signature_single_submitter') %>
          <div class="bsc-accordion-meta">
            <span class="bsc-badge-method bsc-badge-post">POST</span>
            <span class="bsc-badge-endpoint"><%= api_submissions_emails_path %></span>
          </div>
        </span>
      </summary>
      <div class="bsc-accordion-body">
        <% text = capture do %>curl --location '<%= api_submissions_emails_url %>' \
     --header 'X-Auth-Token: API_TOKEN' \
     --data-raw '{
         "template_id": <%= current_account.templates.last&.id || 1 %>,
         "emails": "<%= current_user.email.sub('@', '+test@') %>, <%= current_user.email.sub('@', '+test2@') %>"
     }'<% end.to_str %>
        <%= render 'shared/clipboard_copy', icon: 'copy', text:, class: 'bsc-copy-btn', icon_class: 'w-3 h-3', copy_title: t('copy'), copied_title: t('copied') %>
        <pre><%== HighlightCode.call(text, 'Shell', theme: 'base16.dark') %></pre>
      </div>
    </details>

    <details class="bsc-accordion">
      <summary class="bsc-accordion-head">
        <span>
          <%= t('template_details') %>
          <div class="bsc-accordion-meta">
            <span class="bsc-badge-method bsc-badge-get">GET</span>
            <span class="bsc-badge-endpoint"><%= api_template_path(':id') %></span>
          </div>
        </span>
      </summary>
      <div class="bsc-accordion-body">
        <% text = capture do %>curl '<%= api_template_url(current_account.templates&.last || 1) %>' \
     --header 'X-Auth-Token: API_TOKEN'<% end.to_str %>
        <%= render 'shared/clipboard_copy', icon: 'copy', text:, class: 'bsc-copy-btn', icon_class: 'w-3 h-3', copy_title: t('copy'), copied_title: t('copied') %>
        <pre><%== HighlightCode.call(text, 'Shell', theme: 'base16.dark') %></pre>
      </div>
    </details>

    <div style="display:flex;gap:1rem;flex-wrap:wrap;margin-top:2rem;">
      <%= link_to settings_api_docs_path, class: 'bsc-token-btn', style: 'margin-top:0;padding:0.85rem 2rem;font-size:0.7rem;font-weight:700;letter-spacing:0.12em;text-decoration:none' do %>
        <%= svg_icon('file_text', class: 'w-4 h-4') %>
        API Documentation
      <% end %>
      <a href="<%= "#{Docuseal::PRODUCT_URL}/docs/api" %>" class="bsc-docs-link" target="_blank" rel="noopener" style="margin-top:0">
        Open Full API Reference &#8594;
      </a>
    </div>

  </div>
</div>

