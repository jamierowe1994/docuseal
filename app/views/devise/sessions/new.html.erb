<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Login - Backed.sign</title>
    <style>
        body {
            margin: 0;
            height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #000000;
        }
        .login-card {
            background-color: rgba(255, 255, 255, 0.1);
            border: 1px solid rgba(255, 255, 255, 0.3);
            border-radius: 8px;
            padding: 2rem;
            width: 300px;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.5);
        }
        h1 {
            color: white;
            text-align: center;
            margin: 0 0 1rem;
        }
        input[type="text"], input[type="password"] {
            width: 100%;
            padding: 0.5rem;
            margin-bottom: 1rem;
            border: 1px solid #ccc;
            border-radius: 4px;
            background-color: #333;
            color: white;
        }
        input[type="text"]:focus, input[type="password"]:focus {
            border-color: #6bac36;
            outline: none;
        }
        .submit-button {
            background: linear-gradient(#6bac36, #8ac754);
            color: white;
            padding: 0.5rem;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            width: 100%;
        }
        .oauth-button {
            background-color: #333;
            color: white;
            padding: 0.5rem;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            width: 100%;
            margin-top: 1rem;
        }
        .oauth-button:hover {
            background-color: #444;
        }
    </style>
</head>
<body>
    <div class="login-card">
        <h1>Backed.sign</h1>
        <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
            <%= f.text_field :email, autofocus: true,autocomplete:"email", placeholder:"Email" %>
            <%= f.password_field :password, autocomplete:"current-password", placeholder:"Password" %>
            <%= f.submit "Log in", class: "submit-button" %>
        <% end %>
        <div>
            <%= link_to "Forgot your password?", new_password_path(resource_name), class: "oauth-button" %>
        </div>
        <div>
            <%= link_to "Sign in with Google", "#", class: "oauth-button" %>
            <%= link_to "Sign in with Facebook", "#", class: "oauth-button" %>
        </div>
    </div>
</body>
</html>
