<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In &mdash; backed.sign</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Nunito', sans-serif;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      background: #000000;
      padding: 1.5rem;
    }

    /* faint radial green glow behind the card */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse 60% 50% at 50% 55%, rgba(109,191,84,0.07) 0%, transparent 70%);
      pointer-events: none;
    }

    .login-wrap {
      width: 100%;
      max-width: 520px;
      position: relative;
      z-index: 1;
    }

    .tagline {
      text-align: center;
      color: #ffffff;
      font-weight: 900;
      font-size: clamp(1.9rem, 5vw, 3rem);
      line-height: 1.15;
      letter-spacing: -0.02em;
      margin-bottom: 2.25rem;
    }

    .login-card {
      background: rgba(255, 255, 255, 0.04);
      backdrop-filter: blur(18px);
      -webkit-backdrop-filter: blur(18px);
      border: 1px solid rgba(255, 255, 255, 0.1);
      border-radius: 1.25rem;
      padding: 3rem 3.5rem;
      box-shadow:
        0 0 40px 6px rgba(109, 191, 84, 0.09),
        inset 0 1px 0 rgba(255, 255, 255, 0.07);
    }

    .login-card h2 {
      color: #ffffff;
      font-weight: 800;
      font-size: 1.75rem;
      margin-bottom: 0.4rem;
      letter-spacing: -0.02em;
    }

    .login-card .subtitle {
      color: #7d8674;
      font-size: 0.95rem;
      margin-bottom: 2.25rem;
    }

    .field-group {
      margin-bottom: 1.25rem;
    }

    .field-group label {
      display: block;
      color: #a3ad9a;
      font-size: 0.85rem;
      font-weight: 700;
      letter-spacing: 0.04em;
      text-transform: uppercase;
      margin-bottom: 0.45rem;
    }

    .field-group input {
      width: 100%;
      padding: 0.85rem 1rem;
      background: rgba(255, 255, 255, 0.06);
      border: 1px solid rgba(255, 255, 255, 0.12);
      border-radius: 0.65rem;
      color: #ffffff;
      font-family: 'Nunito', sans-serif;
      font-size: 1rem;
      font-weight: 600;
      transition: border-color 0.15s ease, box-shadow 0.15s ease;
    }

    .field-group input::placeholder { color: #4a5248; }

    .field-group input:focus {
      outline: none;
      border-color: rgba(109, 191, 84, 0.5);
      box-shadow: 0 0 0 3px rgba(109, 191, 84, 0.1);
    }

    .forgot-link {
      display: block;
      text-align: right;
      color: #6dbf54;
      font-size: 0.85rem;
      font-weight: 700;
      text-decoration: none;
      margin-top: -0.75rem;
      margin-bottom: 2rem;
    }
    .forgot-link:hover { text-decoration: underline; }

    .submit-btn {
      width: 100%;
      padding: 0.95rem 1.5rem;
      background: #4a9e3a;
      color: #ffffff;
      font-family: 'Nunito', sans-serif;
      font-size: 1.05rem;
      font-weight: 800;
      border: none;
      border-radius: 9999px;
      cursor: pointer;
      transition: background 0.15s ease, transform 0.15s ease, box-shadow 0.15s ease;
      letter-spacing: 0.01em;
    }

    .submit-btn:hover {
      background: #56b544;
      transform: translateY(-1px);
      box-shadow: 0 6px 20px rgba(109, 191, 84, 0.25);
    }

    .submit-btn:active { transform: translateY(0); }
  </style>
</head>
<body>
  <div class="login-wrap">
    <p class="tagline">"Built for recruiters,<br>by recruiters."</p>
    <div class="login-card">
      <h2>Welcome back</h2>
      <p class="subtitle">Sign in to your account to continue</p>

      <%= form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
        <div class="field-group">
          <label for="user_email">Email address</label>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", placeholder: "you@example.com", id: "user_email" %>
        </div>

        <div class="field-group">
          <label for="user_password">Password</label>
          <%= f.password_field :password, autocomplete: "current-password", placeholder: "••••••••", id: "user_password" %>
        </div>

        <%= link_to "Forgot your password?", new_password_path(resource_name), class: "forgot-link" %>

        <%= f.submit "Sign in", class: "submit-btn" %>
      <% end %>
    </div>
  </div>
</body>
</html>
