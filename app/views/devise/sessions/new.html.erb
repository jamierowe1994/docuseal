<%= content_for(:canonical_url, new_user_session_url) %>

<div class="min-h-screen bg-[#0a0a0a] text-white flex items-center justify-center px-4 py-10">
  <div class="w-full max-w-md">
    <%= render 'devise/shared/select_server' if Docuseal.multitenant? %>

    <div class="rounded-2xl border border-white/10 bg-white/[0.03] backdrop-blur-sm shadow-2xl p-8 md:p-10">
      <div class="text-center mb-8">
        <div class="flex justify-center mb-5">
          <div class="h-12 w-12 rounded-xl border border-white/10 bg-white/5 flex items-center justify-center">
            <span class="text-xl font-black tracking-tight">B</span>
          </div>
        </div>

        <h1 class="text-3xl md:text-4xl font-black tracking-tight text-white">
          backed<span class="text-[#8ac754]">.sign</span>
        </h1>

        <p class="mt-3 text-sm md:text-base text-white/60 leading-relaxed">
          Sign in to manage contracts, templates, and signatures in one place.
        </p>
      </div>

      <%= form_for(resource,
          as: resource_name,
          html: { class: 'space-y-5' },
          data: { turbo: params[:redir].blank? },
          url: session_path(resource_name)) do |f| %>

        <%= render 'hidden_fields' %>

        <div class="space-y-4" dir="auto">
          <div>
            <%= f.label :email, t(:email), class: 'block text-sm font-semibold text-white/80 mb-2' %>
            <%= f.email_field :email,
                autofocus: true,
                autocomplete: 'email',
                placeholder: 'you@company.com',
                class: 'w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-white placeholder:text-white/25 outline-none transition focus:border-[#6bac36] focus:ring-0' %>
          </div>

          <div>
            <%= f.label :password, t(:password), class: 'block text-sm font-semibold text-white/80 mb-2' %>
            <%= f.password_field :password,
                autocomplete: 'current-password',
                placeholder: 'Enter your password',
                class: 'w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-white placeholder:text-white/25 outline-none transition focus:border-[#6bac36] focus:ring-0' %>
          </div>
        </div>

        <div class="pt-2">
          <%= f.button button_title(title: t(:sign_in), disabled_with: t(:signing_in)),
              class: 'w-full rounded-xl bg-[#6bac36] px-4 py-3 text-sm font-bold text-white transition hover:bg-[#8ac754] focus:outline-none focus:ring-0' %>
        </div>
      <% end %>

      <% if devise_mapping.omniauthable? %>
        <div class="mt-6 space-y-3">
          <div class="flex items-center gap-3">
            <div class="h-px flex-1 bg-white/10"></div>
            <span class="text-xs uppercase tracking-[0.2em] text-white/35">or continue with</span>
            <div class="h-px flex-1 bg-white/10"></div>
          </div>

          <% if User.omniauth_providers.include?(:google_oauth2) %>
            <%= form_for '', url: omniauth_authorize_path(resource_name, :google_oauth2), data: { turbo: false }, method: :post do |f| %>
              <set-timezone data-input-id="state" data-params="true"></set-timezone>
              <%= hidden_field_tag :state, { redir: params[:redir].to_s }.compact_blank.to_query %>
              <%= f.button button_title(title: t('sign_in_with_google'), icon: svg_icon('brand_google', class: 'w-5 h-5')),
                  class: 'w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white hover:border-white/20 hover:bg-white/8 mt-2' %>
            <% end %>
          <% end %>

          <% if User.omniauth_providers.include?(:microsoft_office365) %>
            <%= form_for '', url: omniauth_authorize_path(resource_name, :microsoft_office365), data: { turbo: false }, method: :post do |f| %>
              <set-timezone data-input-id="state_microsoft" data-params="true"></set-timezone>
              <%= hidden_field_tag :state, { redir: params[:redir].to_s }.compact_blank.to_query, id: 'state_microsoft' %>
              <%= f.button button_title(title: t('sign_in_with_microsoft'), icon: svg_icon('brand_microsoft', class: 'w-5 h-5')),
                  class: 'w-full rounded-xl border border-white/10 bg-white/5 px-4 py-3 text-sm font-semibold text-white hover:border-white/20 hover:bg-white/8' %>
            <% end %>
          <% end %>
        </div>
      <% end %>

      <div class="mt-6 text-center text-sm text-white/60">
        <%= render 'extra_links' %>
        <%= render 'devise/shared/links' %>
      </div>
    </div>
  </div>
</div>
