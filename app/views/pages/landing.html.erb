<script>
(function () {
  var feeds = {
    bullhorn: {
      label: 'LIVE FEED \u2014 BULLHORN',
      desc: 'Push offer letters directly from Bullhorn placements. Auto-populate candidate data, track signing status in real-time.',
      items: [
        { name: 'Sarah Chen',   status: 'OFFER SENT', time: '2m ago'  },
        { name: 'James Okafor', status: 'SIGNED',     time: '8m ago'  },
        { name: 'Priya Patel',  status: 'VIEWED',     time: '14m ago' }
      ]
    },
    greenhouse: {
      label: 'LIVE FEED \u2014 GREENHOUSE',
      desc: 'Sync offer letters with Greenhouse stages. Trigger signing workflows automatically when candidates reach the offer stage.',
      items: [
        { name: 'Marcus Webb',   status: 'SIGNED',     time: '1m ago'  },
        { name: 'Lena Fischer',  status: 'OFFER SENT', time: '11m ago' },
        { name: 'Tom Bradley',   status: 'VIEWED',     time: '22m ago' }
      ]
    },
    lever: {
      label: 'LIVE FEED \u2014 LEVER',
      desc: 'Connect Lever opportunities to signed documents. Close faster with one-click offer sending from your Lever pipeline.',
      items: [
        { name: 'Amy Liu',     status: 'SIGNED',     time: '5m ago'  },
        { name: 'Raj Sharma',  status: 'OFFER SENT', time: '18m ago' },
        { name: 'Clara Watts', status: 'VIEWED',     time: '31m ago' }
      ]
    },
    jobadder: {
      label: 'LIVE FEED \u2014 JOBADDER',
      desc: 'Integrate with Jobadder placements for seamless e-signing. Candidate records update automatically on signature.',
      items: [
        { name: 'Noah Brown',    status: 'OFFER SENT', time: '3m ago'  },
        { name: 'Sophia Evans',  status: 'SIGNED',     time: '9m ago'  },
        { name: 'Ethan Cole',    status: 'VIEWED',     time: '27m ago' }
      ]
    }
  };

  var panel = document.getElementById('bs-live-feed');
  if (!panel) return;

  var idleHTML = '<p class="bs-int-feed-idle">&#8592; Hover a CRM<br>to see live feed</p>';

  document.querySelectorAll('.bs-crm-row[data-crm]').forEach(function (row) {
    row.addEventListener('mouseenter', function () {
      var key  = this.dataset.crm;
      var feed = feeds[key];
      if (!feed) return;
      var rows = feed.items.map(function (item) {
        return '<div class="bs-lf-row">' +
          '<div><span class="bs-lf-name">' + item.name + '</span>' +
          '<span class="bs-lf-status">' + item.status + '</span></div>' +
          '<span class="bs-lf-time">' + item.time + '</span>' +
          '</div>';
      }).join('');
      panel.innerHTML =
        '<p class="bs-lf-label">' + feed.label + '</p>' +
        '<p class="bs-lf-desc">'  + feed.desc  + '</p>' +
        rows;
    });
  });

  document.querySelector('.bs-int-grid').addEventListener('mouseleave', function () {
    panel.innerHTML = idleHTML;
  });
}());
</script>
