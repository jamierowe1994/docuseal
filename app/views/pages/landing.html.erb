<%# Scoped styles + font loading for the landing page only %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Caveat:wght@700&display=swap" rel="stylesheet">

<style>
  .backed-landing {
    font-family: 'Nunito', sans-serif;
    color: #f5f7f2;
    background:
      radial-gradient(ellipse at 50% 30%, rgba(74, 158, 58, 0.18) 0%, rgba(10, 15, 8, 0) 55%),
      #0a0f08;
    margin: -2rem calc(50% - 50vw) 0;
    padding: 4rem 1.5rem 6rem;
    min-height: calc(100vh - 4rem);
  }
  .backed-landing .wordmark {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: 2.25rem;
    color: #ffffff;
    letter-spacing: -0.02em;
  }
  .backed-landing .wordmark .dot { color: #6dbf54; }
  .backed-landing .wordmark .sign {
    font-family: 'Caveat', cursive;
    font-weight: 700;
    font-size: 2.4rem;
    margin-left: 0.15rem;
  }
  .backed-landing h1.hero {
    font-family: 'Nunito', sans-serif;
    font-weight: 900;
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1.05;
    color: #ffffff;
    letter-spacing: -0.03em;
  }
  .backed-landing h1.hero .accent-dot { color: #6dbf54; }
  .backed-landing .hero-sub {
    color: #b8c2b0;
    font-size: 1.125rem;
    max-width: 36rem;
    margin: 1.25rem auto 2.5rem;
    line-height: 1.55;
  }
  .backed-landing .cta-primary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: #4a9e3a; color: #ffffff;
    padding: 0.9rem 1.75rem; border-radius: 9999px;
    font-weight: 700; text-decoration: none;
    transition: background 0.15s ease, transform 0.15s ease;
  }
  .backed-landing .cta-primary:hover { background: #56b544; transform: translateY(-1px); }
  .backed-landing .cta-secondary {
    display: inline-flex; align-items: center; gap: 0.5rem;
    background: transparent; color: #ffffff;
    padding: 0.9rem 1.75rem; border-radius: 9999px;
    font-weight: 600; text-decoration: none;
    border: 1px solid rgba(255,255,255,0.25);
  }
  .backed-landing .cta-secondary:hover { border-color: #6dbf54; color: #6dbf54; }
  .backed-landing .feature-card {
    background: #131812;
    border: 1px solid rgba(109, 191, 84, 0.12);
    border-radius: 1rem;
    padding: 2.5rem 1.5rem 2rem;
    text-align: center;
    transition: border-color 0.2s ease, transform 0.2s ease;
  }
  .backed-landing .feature-card:hover {
    border-color: rgba(109, 191, 84, 0.4);
    transform: translateY(-2px);
  }
  .backed-landing .feature-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 4rem; height: 4rem;
    background: rgba(109, 191, 84, 0.12);
    border: 1px solid rgba(109, 191, 84, 0.35);
    border-radius: 9999px;
    margin: -3.75rem auto 1.25rem;
  }
  .backed-landing .feature-icon svg { color: #6dbf54; width: 2rem; height: 2rem; }
  .backed-landing .feature-card h3 {
    color: #ffffff; font-weight: 800; font-size: 1.25rem; margin-bottom: 0.75rem;
  }
  .backed-landing .feature-card p { color: #a3ad9a; font-size: 0.975rem; line-height: 1.55; }
  .backed-landing .feature-card a { color: #6dbf54; font-weight: 700; text-decoration: none; }
  .backed-landing .feature-card a:hover { text-decoration: underline; }
  .backed-landing .trust-strip {
    margin-top: 5rem; padding: 2.5rem 1.5rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
    text-align: center; color: #7d8674;
    font-size: 0.9rem; letter-spacing: 0.08em; text-transform: uppercase;
  }
</style>

<section class="backed-landing">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-16">
      <div class="wordmark mb-10">backed<span class="dot">.</span><span class="sign">sign</span></div>
      <h1 class="hero">
        Signing Made<br>For Recruiters<span class="accent-dot">.</span>
      </h1>
      <p class="hero-sub">
        Fast, secure digital document signing built for agencies. Every placement, contract, and offer &mdash; backed<span style="color:#6dbf54">.</span> by us.
      </p>
      <div class="flex flex-wrap gap-4 justify-center">
        <%= link_to 'Get Started', new_user_registration_path, class: 'cta-primary' %>
        <%= link_to 'Sign In', new_user_session_path, class: 'cta-secondary' %>
      </div>
      <% if Docuseal.version.present? %>
        <div class="mt-8">
          <a href="https://github.com/docusealco/docuseal/releases" target="_blank" class="text-xs text-[#7d8674] hover:text-[#6dbf54]">
            v<%= Docuseal.version %>
          </a>
        </div>
      <% end %>
    </div>

    <div class="grid grid-cols-1 gap-8 md:gap-6 md:grid-cols-2 lg:grid-cols-4 mt-24">
      <div class="feature-card">
        <div class="feature-icon"><%= svg_icon('brand_docker', class: 'stroke-1') %></div>
        <h3>Easy to Start</h3>
        <p>Run on your own host with Docker, or deploy to your favorite managed PaaS with a single <a href="https://www.docuseal.com/install">click</a>.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><%= svg_icon('devices') %></div>
        <h3>Mobile Optimized</h3>
        <p>Review and sign documents from any device. Every form is optimized for screens of all sizes.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><%= svg_icon('shield_check') %></div>
        <h3>Secure</h3>
        <p>Self-host behind your VPN so contracts and candidate details never leave your organization.</p>
      </div>
      <div class="feature-card">
        <div class="feature-icon"><%= svg_icon('users') %></div>
        <h3>Built For Recruiters</h3>
        <p>Placement contracts, offer letters, and compliance docs &mdash; templates ready for agency workflows.</p>
      </div>
    </div>

    <div class="trust-strip">
      Trusted by recruitment teams &middot; GDPR-ready &middot; Self-hosted
    </div>
  </div>
</section>

<%= render 'shared/attribution', with_counter: true %>
