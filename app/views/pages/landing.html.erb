<% content_for :hide_navbar, true %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@400;700;900&family=Space+Mono:wght@400;700&family=Space+Grotesk:wght@400;500;600;700&display=swap" rel="stylesheet">

<style>
  /* ── BASE ── */
  .bs {
    font-family: 'Space Grotesk', sans-serif;
    background: #0a0a0a;
    color: #fff;
    margin: -2rem calc(50% - 50vw) 0;
    padding: 0;
    min-height: 100vh;
  }
  .bs *, .bs *::before, .bs *::after { box-sizing: border-box; margin: 0; padding: 0; }
  .bs a { text-decoration: none; }
  .bs-g { color: #6bde2c; }

  /* ── NAV ── */
  .bs-nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(10,10,10,0.96);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }
  .bs-nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.9rem 3rem;
  }
  .bs-wordmark {
    font-family: 'Space Grotesk', sans-serif;
    font-weight: 700; font-size: 1.2rem; color: #fff; letter-spacing: -0.03em;
  }
  .bs-nav-group {
    display: flex; border: 1px solid rgba(255,255,255,0.18); border-radius: 3px;
  }
  .bs-nav-group a {
    color: rgba(255,255,255,0.6); font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase; padding: 0.55rem 1.25rem;
    border-right: 1px solid rgba(255,255,255,0.18);
    transition: color 0.15s, background 0.15s; white-space: nowrap;
  }
  .bs-nav-group a:last-child { border-right: none; }
  .bs-nav-group a:hover { color: #fff; background: rgba(255,255,255,0.05); }
  .bs-btn-green {
    background: #6bde2c; color: #0a0a0a; font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; padding: 0.6rem 1.25rem;
    border-radius: 3px; transition: background 0.15s; white-space: nowrap;
  }
  .bs-btn-green:hover { background: #7fe83d; color: #0a0a0a; }

  /* ── HERO ── */
  .bs-hero { display: grid; grid-template-columns: 1fr 1fr; min-height: calc(100vh - 52px); }
  .bs-hero-l {
    background: #0a0a0a; padding: 5rem 3rem 5rem 5rem;
    display: flex; flex-direction: column; justify-content: center;
  }
  .bs-hero-r {
    background: #141414; display: flex;
    align-items: center; justify-content: center; padding: 3rem 3rem 3rem 2rem;
  }
  .bs-mono-label {
    font-family: 'Space Mono', monospace; font-size: 0.65rem;
    letter-spacing: 0.18em; text-transform: uppercase; color: #6bde2c; margin-bottom: 2rem;
  }
  .bs-title {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 900;
    font-size: clamp(4rem, 7vw, 7rem); line-height: 0.92;
    text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 1.75rem;
  }
  .bs-hero-sub {
    color: rgba(255,255,255,0.55); font-size: 0.975rem;
    line-height: 1.65; max-width: 26rem; margin-bottom: 2.5rem;
  }
  .bs-cta-row { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 3rem; }
  .bs-btn-primary {
    background: #6bde2c; color: #0a0a0a; font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase; padding: 0.875rem 1.75rem;
    border-radius: 3px; transition: background 0.15s;
  }
  .bs-btn-primary:hover { background: #7fe83d; color: #0a0a0a; }
  .bs-btn-outline {
    background: transparent; color: #fff; font-size: 0.75rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase; padding: 0.875rem 1.75rem;
    border-radius: 3px; border: 1px solid rgba(255,255,255,0.28);
    transition: border-color 0.15s, color 0.15s;
  }
  .bs-btn-outline:hover { border-color: #6bde2c; color: #6bde2c; }
  .bs-stats {
    display: grid; grid-template-columns: repeat(3, 1fr);
    border: 1px solid rgba(255,255,255,0.1);
  }
  .bs-stat {
    padding: 1.25rem 1.5rem; border-right: 1px solid rgba(255,255,255,0.1);
    display: flex; flex-direction: column; gap: 0.3rem;
  }
  .bs-stat:last-child { border-right: none; }
  .bs-stat-n {
    font-family: 'Barlow Condensed', sans-serif;
    font-weight: 900; font-size: 1.8rem; line-height: 1; color: #fff;
  }
  .bs-stat-l {
    font-family: 'Space Mono', monospace; font-size: 0.55rem;
    letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.4);
  }

  /* ── DOCUMENT MOCK CARD ── */
  .bs-doc {
    width: 100%; max-width: 340px; background: #1c1c1c;
    border: 1px solid rgba(255,255,255,0.1); border-radius: 6px; padding: 1.25rem;
  }
  .bs-doc-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.4rem; }
  .bs-doc-reflbl {
    font-family: 'Space Mono', monospace; font-size: 0.55rem;
    letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.35);
  }
  .bs-doc-badge {
    background: #6bde2c; color: #0a0a0a; font-family: 'Space Mono', monospace;
    font-size: 0.55rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    padding: 0.2rem 0.5rem; border-radius: 2px;
  }
  .bs-doc-refnum {
    font-family: 'Space Mono', monospace; font-size: 0.95rem; color: #fff;
    padding-bottom: 1rem; margin-bottom: 1rem; border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .bs-doc-typelbl {
    font-family: 'Space Mono', monospace; font-size: 0.55rem;
    letter-spacing: 0.14em; text-transform: uppercase; color: rgba(255,255,255,0.35); margin-bottom: 0.3rem;
  }
  .bs-doc-title { font-family: 'Space Grotesk', sans-serif; font-weight: 700; font-size: 1.05rem; color: #fff; margin-bottom: 0.2rem; }
  .bs-doc-co { font-size: 0.8rem; color: rgba(255,255,255,0.45); margin-bottom: 1rem; }
  .bs-doc-fields { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1rem; }
  .bs-doc-flbl {
    font-family: 'Space Mono', monospace; font-size: 0.5rem;
    letter-spacing: 0.12em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 0.25rem;
  }
  .bs-doc-fval { font-size: 0.85rem; color: #fff; font-weight: 600; }
  .bs-doc-signbtn {
    display: inline-block; background: #6bde2c; color: #0a0a0a;
    font-family: 'Space Mono', monospace; font-size: 0.55rem; font-weight: 700;
    letter-spacing: 0.06em; text-transform: uppercase; padding: 0.2rem 0.5rem;
    border-radius: 2px; margin-bottom: 0.25rem;
  }
  .bs-doc-photo {
    width: 100%; height: 90px; border-radius: 3px; margin-bottom: 1rem;
    background: #2a2a2a; position: relative; overflow: hidden;
  }
  .bs-doc-photo::after {
    content: ''; position: absolute; inset: 0;
    background: repeating-linear-gradient(-45deg, rgba(255,255,255,0.015) 0px, rgba(255,255,255,0.015) 1px, transparent 1px, transparent 6px);
  }
  .bs-doc-sigline {
    border-top: 2px solid #6bde2c; padding-top: 0.5rem;
    font-family: 'Space Mono', monospace; font-size: 0.5rem;
    letter-spacing: 0.1em; text-transform: uppercase; color: rgba(255,255,255,0.3);
  }

  /* ── SHARED SECTION ── */
  .bs-section { border-top: 1px solid rgba(255,255,255,0.08); }
  .bs-section-inner { padding: 6rem 5rem; max-width: 1600px; margin: 0 auto; }
  .bs-seclbl {
    font-family: 'Space Mono', monospace; font-size: 0.65rem;
    letter-spacing: 0.18em; text-transform: uppercase; color: rgba(255,255,255,0.3); margin-bottom: 1.5rem;
  }
  .bs-sectitle {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 900;
    font-size: clamp(3rem, 5.5vw, 5.5rem); line-height: 0.92;
    text-transform: uppercase; letter-spacing: -0.02em; margin-bottom: 1.5rem;
  }
  .bs-secsub { color: rgba(255,255,255,0.5); font-size: 0.95rem; line-height: 1.6; max-width: 28rem; }

  /* ── INTEGRATIONS ── */
  .bs-int-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; padding-top: 4rem; align-items: start; }
  .bs-crm-list { list-style: none; }
  .bs-crm-row {
    display: flex; align-items: center; justify-content: space-between;
    padding: 1.5rem 0.5rem; border-bottom: 1px solid rgba(255,255,255,0.08);
    cursor: default; transition: background 0.2s, padding-left 0.2s;
  }
  .bs-crm-row:first-child { border-top: 1px solid rgba(255,255,255,0.08); }
  .bs-crm-row:hover { background: rgba(255,255,255,0.02); padding-left: 1rem; }
  .bs-crm-left { display: flex; align-items: center; gap: 1.5rem; }
  .bs-crm-idx {
    font-family: 'Space Mono', monospace; font-size: 0.6rem;
    color: rgba(255,255,255,0.25); letter-spacing: 0.05em; min-width: 1.5rem;
  }
  .bs-crm-name {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 900;
    font-size: 2.5rem; text-transform: uppercase; letter-spacing: -0.01em;
    color: #fff; line-height: 1; transition: color 0.15s;
  }
  .bs-crm-row:hover .bs-crm-name { color: #6bde2c; }
  .bs-crm-arrow { color: rgba(255,255,255,0.3); font-size: 1.1rem; transition: color 0.15s, transform 0.15s; }
  .bs-crm-row:hover .bs-crm-arrow { color: #6bde2c; transform: translateX(4px); }
  .bs-crm-hint {
    font-family: 'Space Mono', monospace; font-size: 0.6rem; letter-spacing: 0.14em;
    text-transform: uppercase; color: rgba(255,255,255,0.2); text-align: center; line-height: 2; margin-top: 3rem;
  }

  /* ── TEMPLATES ── */
  .bs-tpl-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    margin-top: 4rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    border-left: 1px solid rgba(255,255,255,0.1);
  }
  .bs-tpl-card {
    border-right: 1px solid rgba(255,255,255,0.1);
    border-bottom: 1px solid rgba(255,255,255,0.1);
    padding: 1.5rem; display: flex; flex-direction: column;
  }
  .bs-tpl-lbl {
    font-family: 'Space Mono', monospace; font-size: 0.55rem;
    letter-spacing: 0.14em; text-transform: uppercase; margin-bottom: 0.4rem;
  }
  .bs-tpl-name {
    font-family: 'Barlow Condensed', sans-serif; font-weight: 900;
    font-size: 1.4rem; text-transform: uppercase; letter-spacing: 0.02em; margin-bottom: 1rem;
  }
  .bs-tpl-preview { height: 180px; border-radius: 2px; margin-bottom: 1rem; }
  .bs-tpl-desc { font-size: 0.82rem; line-height: 1.55; margin-bottom: 0.75rem; flex: 1; }
  .bs-tpl-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 1rem; }
  .bs-tpl-tag {
    font-family: 'Space Mono', monospace; font-size: 0.5rem;
    letter-spacing: 0.08em; text-transform: uppercase;
    border: 1px solid rgba(255,255,255,0.22); border-radius: 2px;
    padding: 0.18rem 0.4rem; color: rgba(255,255,255,0.45);
  }
  .bs-tpl-agency { font-weight: 700; font-size: 0.875rem; }
  /* card variants */
  .bs-tpl-minimal .bs-tpl-lbl  { color: rgba(255,255,255,0.35); }
  .bs-tpl-minimal .bs-tpl-name { color: #fff; }
  .bs-tpl-minimal .bs-tpl-preview { background: #1f1f1f; border: 1px solid rgba(255,255,255,0.08); }
  .bs-tpl-minimal .bs-tpl-desc   { color: rgba(255,255,255,0.5); }
  .bs-tpl-minimal .bs-tpl-agency { color: #fff; }
  .bs-tpl-bold .bs-tpl-lbl  { color: rgba(255,255,255,0.35); }
  .bs-tpl-bold .bs-tpl-name { color: #fff; }
  .bs-tpl-bold .bs-tpl-preview { background: #e8391a; }
  .bs-tpl-bold .bs-tpl-desc   { color: rgba(255,255,255,0.5); }
  .bs-tpl-bold .bs-tpl-agency { color: #fff; }
  .bs-tpl-classic .bs-tpl-lbl  { color: rgba(255,255,255,0.35); }
  .bs-tpl-classic .bs-tpl-name { color: #fff; }
  .bs-tpl-classic .bs-tpl-preview { background: #1a4de8; }
  .bs-tpl-classic .bs-tpl-desc   { color: rgba(255,255,255,0.5); }
  .bs-tpl-classic .bs-tpl-agency { color: #fff; }
  .bs-tpl-tech .bs-tpl-lbl  { color: rgba(107,222,44,0.7); }
  .bs-tpl-tech .bs-tpl-name { color: #6bde2c; }
  .bs-tpl-tech .bs-tpl-preview { background: #0e1a2e; }
  .bs-tpl-tech .bs-tpl-desc { color: #6bde2c; }
  .bs-tpl-tech .bs-tpl-tag { border-color: rgba(107,222,44,0.4); color: #6bde2c; }
  .bs-tpl-tech .bs-tpl-agency { color: #6bde2c; }

  /* ── CAPABILITIES ── */
  .bs-cap-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    margin-top: 4rem;
    border-top: 1px solid rgba(255,255,255,0.08);
    border-left: 1px solid rgba(255,255,255,0.08);
  }
  .bs-cap-item {
    padding: 2.5rem 2rem;
    border-right: 1px solid rgba(255,255,255,0.08);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .bs-cap-icon {
    width: 2.75rem; height: 2.75rem;
    background: rgba(107,222,44,0.08); border: 1px solid rgba(107,222,44,0.25);
    border-radius: 6px; display: flex; align-items: center; justify-content: center; margin-bottom: 1.25rem;
  }
  .bs-cap-icon svg { width: 1.25rem; height: 1.25rem; color: #6bde2c; }
  .bs-cap-title {
    font-size: 0.8rem; font-weight: 700; letter-spacing: 0.06em;
    text-transform: uppercase; color: #fff; margin-bottom: 0.75rem;
  }
  .bs-cap-desc { font-size: 0.875rem; color: rgba(255,255,255,0.5); line-height: 1.6; }

  /* ── RESPONSIVE ── */
  @media (max-width: 1200px) {
    .bs-section-inner { padding: 5rem 3rem; }
    .bs-hero-l { padding: 4rem 3rem; }
    .bs-tpl-grid { grid-template-columns: repeat(2, 1fr); }
    .bs-crm-name { font-size: 2rem; }
  }
  @media (max-width: 900px) {
    .bs-hero { grid-template-columns: 1fr; min-height: auto; }
    .bs-hero-r { display: none; }
    .bs-hero-l { padding: 4rem 2rem; }
    .bs-int-grid { grid-template-columns: 1fr; gap: 3rem; }
    .bs-cap-grid { grid-template-columns: 1fr; }
    .bs-nav-inner { padding: 0.9rem 1.5rem; }
  }
  @media (max-width: 640px) {
    .bs-nav-group { display: none; }
    .bs-tpl-grid { grid-template-columns: 1fr; }
    .bs-stats { grid-template-columns: 1fr; }
    .bs-stat { border-right: none; border-bottom: 1px solid rgba(255,255,255,0.1); }
    .bs-stat:last-child { border-bottom: none; }
    .bs-section-inner { padding: 4rem 1.5rem; }
    .bs-title { font-size: clamp(3.5rem, 12vw, 5rem); }
    .bs-sectitle { font-size: clamp(2.5rem, 10vw, 4rem); }
  }
</style>

<div class="bs">

  <%# ── NAVIGATION ── %>
  <nav class="bs-nav">
    <div class="bs-nav-inner">
      <a href="#" class="bs-wordmark">Backed<span class="bs-g">.</span>sign</a>
      <div class="bs-nav-group">
        <a href="#product">Product</a>
        <a href="#integrations">Integrations</a>
        <a href="#templates">Templates</a>
        <a href="#capabilities">Pricing</a>
      </div>
      <a href="<%= new_user_session_path %>" class="bs-btn-green">Start Signing &#8594;</a>
    </div>
  </nav>

  <%# ── HERO ── %>
  <section class="bs-hero" id="product">
    <div class="bs-hero-l">
      <p class="bs-mono-label">V2.0 &mdash; E-Signature Platform</p>
      <h1 class="bs-title">
        SIGNED<br>
        BY<br>
        <span class="bs-g">RECRUITERS.</span>
      </h1>
      <p class="bs-hero-sub">E-signatures designed by recruiters, for recruiters. Branded templates, CRM integration, and a signing experience worthy of your next great hire.</p>
      <div class="bs-cta-row">
        <a href="<%= new_user_session_path %>" class="bs-btn-primary">Get Started &#8594;</a>
        <a href="#templates" class="bs-btn-outline">View Templates</a>
      </div>
      <div class="bs-stats">
        <div class="bs-stat">
          <span class="bs-stat-n">50K+</span>
          <span class="bs-stat-l">Signatures Sent</span>
        </div>
        <div class="bs-stat">
          <span class="bs-stat-n">99.8%</span>
          <span class="bs-stat-l">Completion Rate</span>
        </div>
        <div class="bs-stat">
          <span class="bs-stat-n">&lt;2m</span>
          <span class="bs-stat-l">Avg Sign Time</span>
        </div>
      </div>
    </div>
    <div class="bs-hero-r">
      <div class="bs-doc">
        <div class="bs-doc-head">
          <span class="bs-doc-reflbl">Document Ref</span>
          <span class="bs-doc-badge">Pending Signature</span>
        </div>
        <div class="bs-doc-refnum">BS-2026-04-0147</div>
        <p class="bs-doc-typelbl">Offer Letter</p>
        <h3 class="bs-doc-title">Senior Product Designer</h3>
        <p class="bs-doc-co">Acme Recruitment Ltd.</p>
        <div class="bs-doc-fields">
          <div>
            <p class="bs-doc-flbl">Start Date</p>
            <p class="bs-doc-fval">2026-05-01</p>
          </div>
          <div>
            <p class="bs-doc-flbl">Compensation</p>
            <span class="bs-doc-signbtn">&#8594; Sign Here</span>
            <p class="bs-doc-fval">&pound;85,000/yr</p>
          </div>
        </div>
        <div class="bs-doc-photo"></div>
        <div class="bs-doc-sigline">Candidate Signature &mdash; 2026-04-20</div>
      </div>
    </div>
  </section>

  <%# ── INTEGRATIONS ── %>
  <section class="bs-section" id="integrations">
    <div class="bs-section-inner">
      <p class="bs-seclbl"><span class="bs-g">002</span> &mdash; Integrations</p>
      <h2 class="bs-sectitle">PLUGS INTO<br>YOUR CRM.</h2>
      <p class="bs-secsub">No migration. No disruption. Backed.sign connects directly to the tools your team already lives in.</p>
      <div class="bs-int-grid">
        <ul class="bs-crm-list">
          <li class="bs-crm-row">
            <div class="bs-crm-left">
              <span class="bs-crm-idx">01</span>
              <span class="bs-crm-name">BULLHORN</span>
            </div>
            <span class="bs-crm-arrow">&#8594;</span>
          </li>
          <li class="bs-crm-row">
            <div class="bs-crm-left">
              <span class="bs-crm-idx">02</span>
              <span class="bs-crm-name">GREENHOUSE</span>
            </div>
            <span class="bs-crm-arrow">&#8594;</span>
          </li>
          <li class="bs-crm-row">
            <div class="bs-crm-left">
              <span class="bs-crm-idx">03</span>
              <span class="bs-crm-name">LEVER</span>
            </div>
            <span class="bs-crm-arrow">&#8594;</span>
          </li>
          <li class="bs-crm-row">
            <div class="bs-crm-left">
              <span class="bs-crm-idx">04</span>
              <span class="bs-crm-name">JOBADDER</span>
            </div>
            <span class="bs-crm-arrow">&#8594;</span>
          </li>
        </ul>
        <div class="bs-crm-hint">Hover a CRM<br>to see live feed</div>
      </div>
    </div>
  </section>

  <%# ── TEMPLATES ── %>
  <section class="bs-section" id="templates">
    <div class="bs-section-inner">
      <p class="bs-seclbl"><span class="bs-g">003</span> &mdash; Templates</p>
      <h2 class="bs-sectitle">YOUR BRAND.<br>NOT OURS.</h2>
      <p class="bs-secsub">Every template is fully customizable. Your logo, your colors, your typography. Backed.sign disappears &mdash; your brand takes center stage.</p>
      <div class="bs-tpl-grid">
        <div class="bs-tpl-card bs-tpl-minimal">
          <p class="bs-tpl-lbl">Template</p>
          <p class="bs-tpl-name">MINIMAL</p>
          <div class="bs-tpl-preview"></div>
          <p class="bs-tpl-desc">Clean lines, generous whitespace, understated authority.</p>
          <div class="bs-tpl-tags">
            <span class="bs-tpl-tag">Cover</span>
            <span class="bs-tpl-tag">Terms</span>
            <span class="bs-tpl-tag">Compensation</span>
          </div>
          <p class="bs-tpl-agency">Apex Talent</p>
        </div>
        <div class="bs-tpl-card bs-tpl-bold">
          <p class="bs-tpl-lbl">Template</p>
          <p class="bs-tpl-name">BOLD</p>
          <div class="bs-tpl-preview"></div>
          <p class="bs-tpl-desc">High-impact, expressive, brand-forward design language.</p>
          <div class="bs-tpl-tags">
            <span class="bs-tpl-tag">Hero Cover</span>
            <span class="bs-tpl-tag">Role Summary</span>
            <span class="bs-tpl-tag">Package</span>
          </div>
          <p class="bs-tpl-agency">Nova Search</p>
        </div>
        <div class="bs-tpl-card bs-tpl-classic">
