<%= render 'shared/turbo_modal', title: 'New Contract', close_after_submit: false do %>
  <toggle-visible data-element-ids='["nc_existing","nc_upload"]' class="block mt-3">
    <div class="flex gap-3 mb-5">
      <span class="flex-1">
        <%= radio_button_tag 'new_contract_tab', 'nc_existing', true,
              class: 'peer hidden',
              data: { action: 'change:toggle-visible#trigger' } %>
        <label for="new_contract_tab_nc_existing"
               class="flex flex-col gap-1 rounded-lg border-2 border-base-300 p-4 cursor-pointer
                      peer-checked:border-primary peer-checked:bg-primary/5
                      hover:border-base-content/30 transition-colors h-full">
          <div class="flex items-center gap-2">
            <%= svg_icon('file_text', class: 'w-5 h-5 text-primary') %>
            <span class="font-semibold text-sm">Use Existing Template</span>
          </div>
          <p class="text-xs text-base-content/60 leading-snug">Choose from your saved templates</p>
        </label>
      </span>
      <span class="flex-1">
        <%= radio_button_tag 'new_contract_tab', 'nc_upload', false,
              class: 'peer hidden',
              data: { action: 'change:toggle-visible#trigger' } %>
        <label for="new_contract_tab_nc_upload"
               class="flex flex-col gap-1 rounded-lg border-2 border-base-300 p-4 cursor-pointer
                      peer-checked:border-primary peer-checked:bg-primary/5
                      hover:border-base-content/30 transition-colors h-full">
          <div class="flex items-center gap-2">
            <%= svg_icon('upload', class: 'w-5 h-5 text-primary') %>
            <span class="font-semibold text-sm">Upload New Template</span>
          </div>
          <p class="text-xs text-base-content/60 leading-snug">Upload a PDF or document to build a new template</p>
        </label>
      </span>
    </div>

    <%# ---- Use Existing Template section ---- %>
    <div id="nc_existing">
      <% if @templates.any? %>
        <div class="flex flex-col gap-1 max-h-72 overflow-y-auto pr-1">
          <% @templates.each do |template| %>
            <%= link_to new_template_submission_path(template),
                        class: 'flex items-center gap-3 rounded-lg border border-base-300 px-4 py-3 hover:border-primary hover:bg-primary/5 transition-colors group',
                        data: { turbo_frame: :modal } do %>
              <%= svg_icon('file_text', class: 'w-5 h-5 text-base-content/40 group-hover:text-primary flex-shrink-0') %>
              <div class="min-w-0 flex-1">
                <div class="font-medium text-sm truncate"><%= template.name %></div>
                <% folder_name = template.folder&.full_name.presence || TemplateFolder::DEFAULT_NAME %>
                <div class="text-xs text-base-content/50 truncate"><%= folder_name %></div>
              </div>
              <%= svg_icon('arrow_right', class: 'w-4 h-4 text-base-content/30 group-hover:text-primary flex-shrink-0') %>
            <% end %>
          <% end %>
        </div>
        <div class="mt-3 text-center">
          <%= link_to 'View all templates →', templates_path, class: 'link text-sm' %>
        </div>
      <% else %>
        <div class="text-center py-6 text-base-content/50">
          <p class="text-sm">No templates yet.</p>
          <p class="text-xs mt-1">Switch to "Upload New Template" to create your first one.</p>
        </div>
      <% end %>
    </div>

    <%# ---- Upload New Template section ---- %>
    <div id="nc_upload" class="hidden">
      <%= form_for '', url: templates_upload_path, id: form_id = SecureRandom.uuid, method: :post, class: 'block', html: { enctype: 'multipart/form-data' }, data: { turbo_frame: :_top } do %>
        <input type="hidden" name="form_id" value="<%= form_id %>">
        <button type="submit" class="hidden"></button>
        <file-dropzone data-submit-on-upload="true" class="w-full">
          <label for="new_contract_file_input" class="w-full block h-48 relative rounded-xl border border-base-300 border-dashed cursor-pointer hover:border-primary/50 transition-colors" data-target="file-dropzone.area">
            <div class="absolute inset-0 flex items-center justify-center p-2 pointer-events-none">
              <div class="flex flex-col items-center text-center gap-3">
                <span data-target="file-dropzone.icon" class="flex flex-col items-center gap-3">
                  <span>
                    <%= svg_icon('upload', class: 'w-10 h-10 text-primary') %>
                  </span>
                  <div class="font-semibold text-sm">Drop your PDF or document here</div>
                  <label for="new_contract_file_input" class="border border-primary/60 text-xs tracking-widest uppercase px-5 py-1.5 cursor-pointer pointer-events-auto hover:bg-primary/10 transition-colors">
                    Select File
                  </label>
                </span>
                <span data-target="file-dropzone.loading" class="flex flex-col items-center hidden gap-3">
                  <%= svg_icon('loader', class: 'w-10 h-10 animate-spin') %>
                  <div class="font-semibold text-sm">Uploading...</div>
                </span>
              </div>
            </div>
            <input id="new_contract_file_input" name="files[]" class="hidden"
                   data-action="change:file-dropzone#onSelectFiles"
                   data-target="file-dropzone.input"
                   type="file"
                   accept="image/*, application/pdf, application/zip, application/json<%= ", #{Templates::CreateAttachments::DOCUMENT_EXTENSIONS.join(', ')}" if Docuseal.advanced_formats? %>"
                   multiple>
          </label>
        </file-dropzone>
      <% end %>
      <p class="text-xs text-base-content/50 text-center mt-2">After uploading, you'll be taken to the template builder to add fields and send your contract.</p>
    </div>
  </toggle-visible>
<% end %>
