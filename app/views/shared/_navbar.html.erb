<%= render 'shared/navbar_warning' %>
<style>
  .bsc-nav {
    position: sticky; top: 0; z-index: 100;
    background: rgba(244,239,230,0.97);
    backdrop-filter: blur(14px);
    border-bottom: 1px solid #E0D7C7;
  }
  .bsc-nav-inner {
    display: flex; align-items: center; justify-content: space-between;
    padding: 0.9rem 3rem;
  }
  .bsc-wordmark {
    font-family: 'Fraunces', serif;
    font-weight: 700; font-size: 1.2rem; color: #1F1B14; letter-spacing: -0.03em;
    text-decoration: none;
  }
  .bsc-wordmark-g { color: #FF6A3D; }
  .bsc-nav-group {
    display: flex; border: 1px solid #E0D7C7;
  }
  .bsc-nav-group a {
    color: rgba(31,27,20,0.55); font-size: 0.7rem; font-weight: 500;
    letter-spacing: 0.12em; text-transform: uppercase; padding: 0.55rem 1.25rem;
    border-right: 1px solid #E0D7C7;
    transition: color 0.15s, background 0.15s; white-space: nowrap;
    text-decoration: none;
  }
  .bsc-nav-group a:last-child { border-right: none; }
  .bsc-nav-group a:hover { color: #1F1B14; background: rgba(31,27,20,0.04); }
  .bsc-nav-group a.bsc-active { color: #FF6A3D; background: rgba(255,106,61,0.05); }
  .bsc-btn-green {
    background: #FF6A3D; color: #FFFFFF; font-size: 0.7rem; font-weight: 700;
    letter-spacing: 0.12em; text-transform: uppercase; padding: 0.6rem 1.25rem;
    border-radius: 0; transition: background 0.15s; white-space: nowrap;
    text-decoration: none;
  }
  .bsc-btn-green:hover { background: #FF8060; color: #FFFFFF; }
  .bsc-btn-logout {
    background: transparent; color: rgba(31,27,20,0.45);
    border: 1px solid #E0D7C7; border-radius: 0;
    width: 2.45rem; height: 2.45rem;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer; transition: color 0.15s, border-color 0.15s, background 0.15s;
    flex-shrink: 0;
  }
  .bsc-btn-logout:hover { color: #1F1B14; border-color: rgba(31,27,20,0.35); background: rgba(31,27,20,0.04); }
  .bsc-btn-logout svg { width: 1rem; height: 1rem; stroke: currentColor; fill: none; stroke-width: 2; stroke-linecap: round; stroke-linejoin: round; }
  .bsc-nav-actions { display: flex; align-items: center; gap: 0.5rem; }
  @media (max-width: 860px) {
    .bsc-nav-inner { padding: 0.9rem 1.5rem; }
  }
  @media (max-width: 640px) {
    .bsc-nav-group { display: none; }
  }
</style>
<nav class="bsc-nav">
  <div class="bsc-nav-inner">
    <a href="<%= root_path %>" class="bsc-wordmark">Backed<span class="bsc-wordmark-g">.</span>sign</a>
    <% if signed_in? %>
      <% if !Docuseal.demo? %>
        <div class="bsc-nav-group">
          <a href="<%= settings_api_index_path %>" class="<%= 'bsc-active' if request.path.start_with?('/settings/api') %>">Integrations</a>
          <a href="<%= templates_path %>" class="<%= 'bsc-active' if request.path.start_with?('/templates') || request.path == '/' %>">Templates</a>
          <a href="<%= contracts_path %>" class="<%= 'bsc-active' if request.path.start_with?('/contracts') %>">Contracts</a>
          <a href="<%= settings_users_path %>" class="<%= 'bsc-active' if request.path.start_with?('/settings') && !request.path.start_with?('/settings/api') %>">Admin</a>
        </div>
        <div class="bsc-nav-actions">
          <%= link_to new_contract_path, class: 'bsc-btn-green', data: { turbo_frame: :modal } do %>
            New Contract &#8594;
          <% end %>
          <%= button_to destroy_user_session_path, method: :delete, data: { turbo: false }, class: 'bsc-btn-logout', title: t('sign_out') do %>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
          <% end %>
        </div>
      <% else %>
        <div class="bsc-nav-actions">
          <a href="https://docuseal.com/sign_up" class="bsc-btn-green"><%= t('sign_up') %></a>
        </div>
      <% end %>
    <% else %>
      <div class="bsc-nav-actions">
        <% if request.path != new_user_session_path && request.path != setup_index_path %>
          <%= link_to new_user_session_path({ lang: params[:lang] }.compact_blank), class: 'bsc-btn-green' do %>
            <%= t('sign_in') %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </div>
</nav>

